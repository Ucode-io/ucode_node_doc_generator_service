// Utility function to upload file to CDN and return link
async function uploadToCDN(filePath, fileName) {
    try {
        // Read file as base64
        const fileData = fs.readFileSync(filePath);
        const base64FileData = fileData.toString('base64');

        // For demonstration, we'll use the same ConvertAPI service to store the file
        // In production, you might want to use a dedicated CDN service
        const payload = {
            Parameters: [
                {
                    Name: 'File',
                    FileValue: {
                        Name: fileName,
                        Data: base64FileData
                    }
                },
                {
                    Name: 'StoreFile',
                    Value: true
                }
            ]
        };

        // Use the first convert API secret for file storage
        const convertapi_secret = convertapi_secrets[0];
        
        const response = await axios.post(
            `https://v2.convertapi.com/convert/pdf/to/pdf?Secret=${convertapi_secret}`,
            payload,
            {
                headers: {
                    'Content-Type': 'application/json',
                },
            }
        );

        if (response.data && response.data.Files && response.data.Files[0]) {
            return response.data.Files[0].Url;
        }
        
        throw new Error('Failed to upload to CDN');
    } catch (error) {
        console.error('Error uploading to CDN:', error);
        throw error;
    }
}

